# ============================================================
# Weather Station - Variables de entorno
# Copia este archivo como .env y completa los valores
# ============================================================

# --- DuckDNS ---
DUCKDNS_TOKEN=tu-token-aqui          # En duckdns.org → tu cuenta
DUCKDNS_DOMAIN=tu-subdominio         # Solo el subdominio, sin .duckdns.org

# --- Nginx (debe coincidir con DUCKDNS_DOMAIN) ---
NGINX_HOST=tu-subdominio.duckdns.org

# --- Base de datos (SQLite por defecto, no cambiar) ---
DATABASE_URL=sqlite:////data/weather.db
